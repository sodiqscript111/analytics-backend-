        {
          "expr": "histogram_quantile(0.95, sum by (le, source, status) (rate(analytics_search_query_duration_seconds_bucket[5m])))",
          "legendFormat": "search {{source}} {{status}}",
          "refId": "B"
        }
      ],
      "title": "P95 API Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
